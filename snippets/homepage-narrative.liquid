<script>
  /* CTA button scrolls to top and opens Aero */
  document.addEventListener('DOMContentLoaded', function() {
    var ctaBtn = document.getElementById('convo-cta-trigger');
    if (ctaBtn) {
      ctaBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        setTimeout(function() {
          var heroInput = document.getElementById('aero-hero-input');
          if (heroInput) {
            heroInput.focus();
          }
        }, 800);
      });
    }
  });
</script>
