<!-- SECTION: Final CTA                         -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-cta convo-reveal-group">
  <h2 class="convo-cta__heading convo-reveal">
    What would change if nothing you've figured out ever got lost again?
  </h2>
  <p class="convo-cta__body convo-reveal">
    Start with a free Seed Doc conversation. No intake forms — just a thinking partnership.
  </p>
  <div class="convo-reveal">
    <button class="convo-cta__button" id="convo-cta-trigger">Start Your Seed Doc →</button>
  </div>
</div>

<script>
  /* CTA button scrolls to top and opens Aero */
  document.addEventListener('DOMContentLoaded', function() {
    var ctaBtn = document.getElementById('convo-cta-trigger');
    if (ctaBtn) {
      ctaBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        setTimeout(function() {
          var heroInput = document.getElementById('aero-hero-input');
          if (heroInput) {
            heroInput.focus();
          }
        }, 800);
      });
    }
  });
</script>
