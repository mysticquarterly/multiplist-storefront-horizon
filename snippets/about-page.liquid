<style>
  .about-story {
    background: #1a1612;
    border-top: 1px solid #3b3530;
    border-bottom: 1px solid #3b3530;
    padding: 80px 24px;
  }

  .about-story__inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-story .convo-body strong {
    color: #E8DDD6;
  }

  .about-story .convo-heading {
    color: #E8DDD6;
  }

  .about-story .convo-speaker {
    color: #8a7d73;
  }

  .about-story .convo-divider {
    background: #3b3530;
  }

  .about-story .convo-speaker__dot {
    background: #E8DDD6;
  }

  /* ── Law of Recursion ── */
  .recursion-forces {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }

  .recursion-force {
    padding: 32px 28px;
    border-radius: 14px;
    border: 1px solid #3b3b3b;
    transition: border-color 0.3s ease;
  }

  .recursion-force:hover {
    border-color: #1891AB;
  }

  .recursion-force--jupiter {
    background: linear-gradient(145deg, #1a1a2e 0%, #1a1a1a 100%);
    border-color: #2a2a4a;
  }

  .recursion-force--jupiter:hover {
    border-color: #6a5acd;
  }

  .recursion-force--saturn {
    background: linear-gradient(145deg, #1e1a14 0%, #1a1a1a 100%);
    border-color: #3b3530;
  }

  .recursion-force--saturn:hover {
    border-color: #E8DDD6;
  }

  .recursion-force__symbol {
    font-size: 2rem;
    margin-bottom: 12px;
    line-height: 1;
  }

  .recursion-force--jupiter .recursion-force__symbol {
    color: #6a5acd;
  }

  .recursion-force--saturn .recursion-force__symbol {
    color: #E8DDD6;
  }

  .recursion-force__name {
    font-family: var(--font-heading--family, 'Inter', sans-serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: #EAEAEA;
    margin: 0 0 12px;
  }

  .recursion-force__body {
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #a6a6a6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .recursion-forces {
      grid-template-columns: 1fr;
    }
  }
</style>
