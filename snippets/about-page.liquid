{% render 'conversation-reveal' %}

<!-- ═══════════════════════════════════════════ -->
<!-- MISSION                                     -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-section convo-reveal-group" style="text-align: center; padding-bottom: 40px;">
  <div class="convo-reveal">
    <div class="convo-speaker" style="justify-content: center;">
      <div class="convo-speaker__dot"></div>
      Our mission
    </div>
    <div class="convo-divider convo-divider--center"></div>
  </div>

  <h1 class="convo-heading convo-heading--large convo-reveal">
    Teaching people to relate with AI in a more intuitive, collaborative way
  </h1>

  <p class="convo-body convo-reveal" style="text-align: center; max-width: 600px; margin: 0 auto;">
    Not as a tool to be mastered. Not as a replacement to be feared. As a <em>thinking partner</em> — a co-intelligence that grows with you and preserves the work that matters.
  </p>
