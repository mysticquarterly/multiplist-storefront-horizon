{% comment %}
  Contact Page — WhatsApp as primary CTA, email as secondary.
  Uses the conversation-reveal design system.
{% endcomment %}

{% render 'conversation-reveal' %}

<!-- ═══════════════════════════════════════════ -->
<!-- HEADER                                      -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-section convo-reveal-group" style="text-align: center; padding-bottom: 20px;">
  <div class="convo-reveal">
    <div class="convo-speaker" style="justify-content: center;">
      <div class="convo-speaker__dot"></div>
      Let's talk
    </div>
    <div class="convo-divider convo-divider--center"></div>
  </div>

  <h1 class="convo-heading convo-heading--large convo-reveal">
    Start a Conversation
  </h1>

  <p class="convo-body convo-reveal" style="text-align: center; max-width: 560px; margin: 0 auto;">
    Whether you're curious about an Intelligence Field, ready to book a service, or just want to say hi — the fastest way to reach me is WhatsApp.
  </p>
</div>

<!-- ═══════════════════════════════════════════ -->
<!-- WHATSAPP CTA                                -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-section convo-reveal-group" style="padding-top: 0;">
  <div class="contact-card contact-card--whatsapp convo-reveal">
    <div class="contact-card__icon">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="#25D366">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </div>
    <h2 class="contact-card__heading">Message me on WhatsApp</h2>
    <p class="contact-card__body">Tap below to open a chat. I typically respond within a few hours. Async-first — message anytime.</p>
    <a href="https://wa.me/12068169316?text=Hi%20Amy!%20I%20found%20you%20through%20Multiplist%20Studios." class="contact-card__button contact-card__button--whatsapp" target="_blank" rel="noopener">
      Open WhatsApp Chat
    </a>
  </div>
</div>

<!-- ═══════════════════════════════════════════ -->
<!-- SECONDARY OPTIONS                           -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-section convo-reveal-group" style="padding-top: 0;">
  <div class="convo-reveal">
    <div class="convo-speaker">
      <div class="convo-speaker__dot"></div>
      Other ways to connect
    </div>
    <div class="convo-divider"></div>
  </div>

  <div class="contact-options convo-reveal">
    <div class="contact-option">
      <div class="contact-option__icon">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#1891AB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <div class="contact-option__text">
        <h3 class="contact-option__label">Email</h3>
        <a href="mailto:hello@multiplist.ai" class="contact-option__link">hello@multiplist.ai</a>
      </div>
    </div>

    <div class="contact-option">
      <div class="contact-option__icon">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#1891AB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          <path d="M2 12h20"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
      </div>
      <div class="contact-option__text">
        <h3 class="contact-option__label">Main Website</h3>
        <a href="https://multiplist.ai" class="contact-option__link" target="_blank" rel="noopener">multiplist.ai</a>
      </div>
    </div>

    <div class="contact-option">
      <div class="contact-option__icon">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#1891AB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polygon points="10 8 16 12 10 16 10 8"/>
        </svg>
      </div>
      <div class="contact-option__text">
        <h3 class="contact-option__label">Free Seed Doc</h3>
        <a href="/" class="contact-option__link">Talk to Aero — no forms needed</a>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════ -->
<!-- CTA                                         -->
<!-- ═══════════════════════════════════════════ -->
<div class="convo-cta convo-reveal-group">
  <h2 class="convo-cta__heading convo-reveal">Not sure what you need?</h2>
  <p class="convo-cta__body convo-reveal">
    That's what the Seed Doc is for. Start a free conversation with Aero and we'll figure it out together.
  </p>
  <div class="convo-reveal">
    <a href="/" class="convo-cta__button" style="text-decoration: none;">Start Your Seed Doc &rarr;</a>
  </div>
</div>

<style>
  /* ── WhatsApp card ── */
  .contact-card {
    background: #1a1a1a;
    border: 1px solid #3b3b3b;
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    transition: border-color 0.3s ease;
  }

  .contact-card:hover {
    border-color: #25D366;
  }

  .contact-card__icon {
    margin-bottom: 20px;
  }

  .contact-card__heading {
    font-family: var(--font-heading--family, 'Inter', sans-serif);
    font-size: 1.375rem;
    font-weight: 600;
    color: #EAEAEA;
    margin: 0 0 12px;
  }

  .contact-card__body {
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #a6a6a6;
    margin: 0 0 28px;
  }

  .contact-card__button {
    display: inline-block;
    padding: 14px 36px;
    border-radius: 8px;
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .contact-card__button--whatsapp {
    background: #25D366;
    color: #fff;
  }

  .contact-card__button--whatsapp:hover {
    background: #1ebe57;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.3);
  }

  /* ── Secondary options ── */
  .contact-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }

  .contact-option {
    background: #1a1a1a;
    border: 1px solid #3b3b3b;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    transition: border-color 0.3s ease;
  }

  .contact-option:hover {
    border-color: #1891AB;
  }

  .contact-option__icon {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-option__label {
    font-family: var(--font-heading--family, 'Inter', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: #EAEAEA;
    margin: 0 0 4px;
  }

  .contact-option__link {
    font-family: var(--font-body--family, 'Inter', sans-serif);
    font-size: 0.875rem;
    color: #1891AB;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-option__link:hover {
    color: #0097b2;
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .contact-card {
      padding: 36px 24px;
    }

    .contact-options {
      grid-template-columns: 1fr;
    }
  }
</style>
