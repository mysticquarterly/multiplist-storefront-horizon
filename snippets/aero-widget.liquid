{% comment %}
  Aero Storefront Intelligence Engine - Chat Widget
  Connects to V12 API on Railway for Seed Doc conversations.
  Endpoint URL will be updated when V12 Sprint 2 API is deployed.
{% endcomment %}

{% if template.name != 'password' %}
<style>
  .aero-widget-trigger {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: {{ settings.color_schemes['scheme-8'].settings.primary | default: '#0097b2' }};
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    z-index: 9999;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .aero-widget-trigger:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.4);
  }
  .aero-widget-trigger svg {
    width: 24px;
    height: 24px;
  }
  .aero-widget-panel {
    position: fixed;
    bottom: 96px;
    right: 24px;
    width: 380px;
    max-height: 520px;
    background: #1a1a1a;
    border: 1px solid #3b3b3b;
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    z-index: 9998;
    display: none;
    flex-direction: column;
    overflow: hidden;
    font-family: var(--font-body--family, 'Inter', sans-serif);
  }
  .aero-widget-panel.is-open {
    display: flex;
  }
  .aero-widget-header {
    padding: 16px 20px;
    border-bottom: 1px solid #3b3b3b;
    color: #e0e0e0;
    font-size: 0.875rem;
    font-weight: 500;
  }
  .aero-widget-header span {
    color: #0097b2;
  }
  .aero-widget-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
    min-height: 300px;
    color: #e0e0e0;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .aero-widget-input-area {
    padding: 12px 16px;
    border-top: 1px solid #3b3b3b;
    display: flex;
    gap: 8px;
  }
  .aero-widget-input {
    flex: 1;
    background: #262626;
    border: 1px solid #3b3b3b;
    border-radius: 8px;
    padding: 10px 14px;
    color: #e0e0e0;
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
    resize: none;
  }
  .aero-widget-input::placeholder {
    color: #a6a6a6;
  }
  .aero-widget-input:focus {
    border-color: #0097b2;
  }
  .aero-widget-send {
    background: #0097b2;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    color: #fff;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .aero-widget-panel {
      width: calc(100vw - 32px);
      right: 16px;
      bottom: 88px;
      max-height: 70vh;
    }
  }
</style>

<button class="aero-widget-trigger" id="aero-trigger" aria-label="Open Aero Intelligence">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<div class="aero-widget-panel" id="aero-panel">
  <div class="aero-widget-header">
    <span>Aero</span> · Multiplist Intelligence Engine
  </div>
  <div class="aero-widget-messages" id="aero-messages">
    <p>What does your work create — and what would change if nothing you've figured out ever got lost again?</p>
  </div>
  <div class="aero-widget-input-area">
    <textarea class="aero-widget-input" id="aero-input" placeholder="Share what's on your mind..." rows="1"></textarea>
    <button class="aero-widget-send" id="aero-send">Send</button>
  </div>
</div>

<script>
  (function() {
    const trigger = document.getElementById('aero-trigger');
    const panel = document.getElementById('aero-panel');

    if (trigger && panel) {
      trigger.addEventListener('click', function() {
        panel.classList.toggle('is-open');
      });
    }

    /* V12 API integration placeholder
     * Endpoint: https://your-v12-instance.railway.app/api/aero/chat
     * Method: POST with SSE streaming
     * When Sprint 2 API is deployed, replace this with actual fetch logic
     */
  })();
</script>
{% endif %}
